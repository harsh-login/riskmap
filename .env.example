# ContagionMap — Environment Configuration
# Do not commit this file to version control

DB_HOST=localhost
DB_PORT=3306
DB_NAME=contagionmap_db
DB_USER=contagion_user
DB_PASSWORD=your_password

# Random seed for reproducible data generation
RANDOM_SEED=42

# MSI thresholds (configurable — see MSI_METHODOLOGY.md)
MSI_WATCH_THRESHOLD=40
MSI_ELEVATED_THRESHOLD=60
MSI_CRITICAL_THRESHOLD=80

# BFS depth cap
CONTAGION_MAX_DEPTH=3
